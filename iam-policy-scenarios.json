## Scenario 9: Data Scientist Notebook Access

**Use Case**: Data scientist can read training datasets, write analysis output, no deletion

```json
{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowReadDatasets",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::ml-datasets-bucket",
        "arn:aws:s3:::ml-datasets-bucket/training-data/*"
      ]
    },
    {
      "Sid": "AllowWriteOutput",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject"
      ],
      "Resource": "arn:aws:s3:::ml-output-bucket/notebooks/*/",
      "Condition": {
        "StringEquals": {
          "aws:username": "${aws:username}"
        }
      }
    },
    {
      "Sid": "DenyDelete",
      "Effect": "Deny",
      "Action": [
        "s3:DeleteObject",
        "s3:DeleteBucket"
      ],
      "Resource": "*"
    }
  ]
}
```

